# ai-engine/.env.example
# Copy to .env and fill in the values that apply.

# ── LLM Provider ─────────────────────────────────────────
# "groq"   → Groq API (free tier, recommended — https://console.groq.com)
# "gemini" → Google Gemini API  (https://aistudio.google.com)
LLM_PROVIDER=groq

# ── Groq (free, fast — get key at https://console.groq.com) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Alternatives: llama-3.1-8b-instant  mixtral-8x7b-32768  deepseek-r1-distill-llama-70b

# ── Gemini (optional fallback — set LLM_PROVIDER=gemini to use) ──
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Shared LLM settings ───────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

# ── Agent behaviour ───────────────────────────────────────
DEFAULT_MAX_ITERATIONS=5

# ── Git identity used on commits ──────────────────────────
GIT_AUTHOR_NAME=CI Healer Agent
GIT_AUTHOR_EMAIL=agent@cihealer.dev
GIT_COMMIT_PREFIX=[AI-AGENT]

# ── Workspace ─────────────────────────────────────────────
# Local dev: relative path inside ai-engine/
# Docker / Railway: leave as /workspace (volume mounted)
WORKSPACE_DIR=./workspace

# ── Internal API ──────────────────────────────────────────
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8001

# ── CORS ──────────────────────────────────────────────────
# Set to your backend's origin in production so the engine
# rejects requests from any other host.
# BACKEND_ORIGIN=https://your-backend.railway.app
