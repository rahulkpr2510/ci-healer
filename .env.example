# .env — Root environment file for docker-compose
# Copy this file to .env and fill in all required values.
# This file is used only by docker-compose; individual services
# have their own .env files for local (non-Docker) development.

# ── LLM Provider (AI Engine) ──────────────────────────────
# "groq" is recommended — free, fast, no credit card required
# Get key at: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (optional — only needed if LLM_PROVIDER=gemini)
# Get key at: https://aistudio.google.com
GOOGLE_API_KEY=

# ── GitHub OAuth App ──────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Homepage URL:           http://localhost:3000
# Authorization callback: http://localhost:8000/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# ── JWT ───────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_random_32_char_string

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=cihealer
POSTGRES_PASSWORD=cihealer_dev
POSTGRES_DB=cihealer

# ── URLs ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Agent ─────────────────────────────────────────────────
DEFAULT_MAX_ITERATIONS=5
GIT_AUTHOR_NAME=CI Healer Bot
GIT_AUTHOR_EMAIL=bot@cihealer.dev
